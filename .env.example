# ============================================================
# WA Sender Pro — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=change-me-to-a-random-32-char-string

# --- WuzAPI ---
WUZAPI_URL=http://wuzapi:3100
WUZAPI_TOKEN=your-secret-wuzapi-token

# --- Database ---
DATABASE_URL="file:./data/wa-sender-pro.db"

# --- Campaign Defaults ---
# Delay between messages in seconds (min/max for randomization)
CAMPAIGN_DELAY_MIN=15
CAMPAIGN_DELAY_MAX=45

# --- Rate Limiting ---
# Max messages per hour (safety cap)
MAX_MESSAGES_PER_HOUR=100
